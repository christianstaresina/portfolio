---
import { variants } from "../../data/site";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>Portfolio design variants</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600&family=IBM+Plex+Serif:wght@600&display=swap");

      :root {
        color-scheme: light dark;
        --bg: #111418;
        --ink: #edf0f4;
        --muted: #9aa3ae;
        --line: rgba(237, 240, 244, 0.14);
        --accent: #c45c26;
        --surface: #1a1f26;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--ink);
        font-family: "IBM Plex Sans", sans-serif;
        background:
          radial-gradient(circle at 80% 0%, rgba(196, 92, 38, 0.18), transparent 28rem),
          var(--bg);
      }

      main {
        width: min(100%, 900px);
        margin: 0 auto;
        padding: 3rem 1.25rem 4rem;
      }

      a {
        color: inherit;
      }

      .back {
        color: var(--muted);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-decoration: none;
        text-transform: uppercase;
      }

      h1 {
        margin: 1.5rem 0 0.75rem;
        font-family: "IBM Plex Serif", Georgia, serif;
        font-size: clamp(2.4rem, 6vw, 3.6rem);
        line-height: 1;
      }

      .intro {
        max-width: 38rem;
        margin: 0 0 2rem;
        color: var(--muted);
        line-height: 1.65;
      }

      ul {
        display: grid;
        gap: 1px;
        margin: 0;
        padding: 1px;
        background: var(--line);
        list-style: none;
      }

      li a {
        display: block;
        padding: 1.35rem 1.25rem;
        background: var(--surface);
        text-decoration: none;
      }

      li a:hover {
        outline: 1px solid var(--accent);
      }

      .name {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.45rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .name span:last-child {
        color: var(--accent);
        font-size: 0.75rem;
      }

      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.55;
      }
    </style>
  </head>
  <body>
    <main>
      <a class="back" href="/">← Production site (Signal)</a>
      <h1>Design variants</h1>
      <p class="intro">
        Local mockups kept for comparison. Production uses the Signal design.
        Each variant includes a simple menu, dark/light toggle, and pages for
        home, résumé, and hobbies. About is hidden until content is ready.
      </p>
      <ul>
        {
          variants.map((variant) => (
            <li>
              <a href={`/variants/${variant.id}/`}>
                <div class="name">
                  <span>{variant.name}</span>
                  <span>Open</span>
                </div>
                <p>{variant.tagline}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
